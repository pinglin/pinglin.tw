---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';
import { languages, defaultLang } from '../i18n/ui';

import config from '../config.json';

const t = useTranslations(
  (Astro.currentLocale ?? defaultLang).replace('_', '-') as keyof typeof languages,
);
---

<BaseLayout pageTitle={t('home.title')}>
  <div class="flex flex-col justify-center items-center h-full leading-loose">
    <h2>👋 Hi, I am Pinglin.</h2>
    <br />
    <p>
      Press <kbd class="kbd kbd-sm">CMD</kbd> + <kbd class="kbd kbd-sm">K</kbd> to search.
    </p>
    <div
      id="globe-container"
      class="relative opacity-0 transition-opacity duration-1000"
      style=`width:${config.globeViewWidth}px; height: ${config.globeViewHeight}px`
    >
      <div id="globe-point-cloud"></div>
      <div
        id="globe-status"
        class="pointer-events-none absolute left-2 bottom-2 text-[11px] font-mono leading-tight text-gray-500 dark:text-gray-300/80"
      >
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  type Visit = {
    id: string;
    ts: number;
    source: { lat: number; lng: number; city?: string; country?: string };
    server: { lat: number; lng: number; code: string; label: string };
    demo?: boolean;
  };

  type HistoricalVisit = Visit & {
    legacyCount?: number;
    legacyFirstTs?: number;
  };

  const VISIT_HISTORY_MS = 24 * 60 * 60 * 1000;

  const initHomeGlobe = async () => {
    const { initGlobe } = await import('@/scripts/three-globe/globe.js');
    const globe = initGlobe();

    setTimeout(() => {
      document.getElementById('globe-container')?.classList.remove('opacity-0');
    }, 100);

    const status = document.getElementById('globe-status');
    const seen = new Set<string>();
    let lastTs = 0;

    const renderStatus = (visit: Visit | null, server: Visit['server'] | null) => {
      if (!status) return;
      const here = visit
        ? `${visit.source.city ?? '—'}${visit.source.country ? `, ${visit.source.country}` : ''}`
        : '—';
      const there = server ? `${server.label} (${server.code})` : '—';
      status.textContent = `You are\n→ from ${here}\n→ to ${there}`;
      status.style.whiteSpace = 'pre';
    };

    const ingest = (visits: Visit[]) => {
      for (const v of visits) {
        if (seen.has(v.id)) continue;
        seen.add(v.id);
        lastTs = Math.max(lastTs, v.ts);
        globe.addVisit(v);
      }
    };

    const fetchVisits = async (since = lastTs, includeHistory = false) => {
      try {
        const historyParam = includeHistory ? '&history=1' : '';
        const res = await fetch(`/api/visit.json?since=${since}${historyParam}`, {
          cache: 'no-store',
        });
        if (!res.ok) return;
        const { visits, history, server } = (await res.json()) as {
          visits: Visit[];
          history?: HistoricalVisit[];
          server: Visit['server'];
        };
        if (server) globe.setServerBeacon(server);
        if (history) globe.setHistory(history);
        ingest(visits);
      } catch {
        /* swallow */
      }
    };

    try {
      const ownRes = await fetch('/api/visit.json', { method: 'POST' });
      if (ownRes.ok) {
        const { visit, server } = (await ownRes.json()) as {
          visit: Visit;
          server: Visit['server'];
        };
        globe.setServerBeacon(server);
        ingest([visit]);
        renderStatus(visit, server);
      }
    } catch {
      /* network errors are non-fatal — the globe still spins */
    }

    await fetchVisits(Date.now() - VISIT_HISTORY_MS, true);

    setInterval(() => fetchVisits(), 4000);
    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') fetchVisits(lastTs, true);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHomeGlobe, { once: true });
  } else {
    initHomeGlobe();
  }
</script>
