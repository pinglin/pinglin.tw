---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeGlobe from '../../components/HomeGlobe.astro';
import { useTranslations } from '../../i18n/utils';
import { languages, defaultLang } from '../../i18n/ui';

const t = useTranslations(
  (Astro.currentLocale ?? defaultLang).replace('_', '-') as keyof typeof languages,
);
---

<BaseLayout pageTitle={t('home.title')}>
  <div class="flex flex-col justify-center items-center h-full leading-loose">
    <h2>👋 你好，我是秉霖。</h2>
    <br />
    <p>
      按 <kbd class="kbd kbd-sm">CMD</kbd> + <kbd class="kbd kbd-sm">K</kbd> 進行搜尋。
    </p>
    <HomeGlobe statusHeading="你目前的連線" fromLabel="從" toLabel="到" />
  </div>
</BaseLayout>
